      "parameters": {
        "functionCode": "const chunkSize = 1000;\nlet newItems = [];\nfor (const item of items) {\n  const text = item.json.summary || '';\n  for (let i = 0; i < text.length; i += chunkSize) {\n    newItems.push({ json: { ...item.json, chunk: text.slice(i, i+chunkSize) }});\n  }\n}\nreturn newItems;"
