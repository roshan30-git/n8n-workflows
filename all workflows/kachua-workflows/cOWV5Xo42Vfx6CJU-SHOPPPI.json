    {
      "parameters": {
        "functionCode": "const productName = $json[\"name\"];\nlet apiSource = \"Pexels\";\nlet url = `https://api.pexels.com/v1/search?query=${encodeURIComponent(productName + \" jewelry\")}&per_page=5`;\nif ($json[\"PexelsLimitReached\"]) {\n  apiSource = \"Unsplash\";\n  url = `https://api.unsplash.com/search/photos?query=${encodeURIComponent(productName + \" jewelry\")}&per_page=5&client_id=YOUR_UNSPLASH_KEY`;\n}\nreturn { json: { apiSource, url } };"
      },
