        "functionCode": "const productsFromAli = $json[\"AliExpressProducts\"] || [];\nconst productsFromSaleHoo = $json[\"SaleHooProducts\"] || [];\nconst selectedProducts = productsFromAli.length > 0 ? productsFromAli.slice(0,5) : productsFromSaleHoo.slice(0,5);\nreturn selectedProducts.map(p => ({ json: { name: p.title || p.name, url: p.link, price: p.price, supplier: p.supplier || \"Unknown\" } }));"
      },
