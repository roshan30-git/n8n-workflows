        "jsCode": "const results = [];\n\n$input.all().forEach((item) => {\n  if (item.json.audios) {\n    item.json.audios.forEach((audio) => {\n      results.push({\n        json: {\n          source: \"Sarvam API\",\n        },\n        binary: {\n          data: {\n            data: Buffer.from(audio, \"base64\"),\n            mimeType: audio.format === \"mp3\" ? \"audio/mpeg\" : \"audio/wav\",\n            fileName: `sarvam_output.${audio.format}`,\n          },\n        },\n      });\n    });\n  }\n});\n\nreturn results;\n"
      },
