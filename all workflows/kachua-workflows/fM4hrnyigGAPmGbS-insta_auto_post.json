        "jsCode": "// Create comprehensive report for all processed images\nconst allResults = $json.all_results;\nconst firstResult = allResults[0];\n\n// Create summary document content\nconst reportContent = `# Product Analysis Report\\n**Generated:** ${new Date().toISOString()}\\n**Total Images Processed:** ${allResults.length}\\n**Source:** ${firstResult.image_info.source}\\n\\n---\\n\\n${allResults.map((result, index) => {\n  return `## Image ${result.image_info.index}: ${result.image_info.filename}\\n\\n### Product Analysis\\n${result.analysis.product_analysis}\\n\\n### SEO Content\\n**Top Title:** ${result.seo_content.titles[0] || 'N/A'}\\n**Meta Description:** ${result.seo_content.meta_description}\\n**SEO Tags:** ${result.seo_content.seo_tags.join(', ')}\\n**Call to Action:** ${result.seo_content.call_to_action}\\n\\n**Product Description:**\\n${result.seo_content.product_description}\\n\\n### Advertisement Prompts\\n\\n**Lifestyle Ad Prompt:**\\n${result.ad_prompts.lifestyle}\\n\\n**Minimalist Ad Prompt:**\\n${result.ad_prompts.minimalist}\\n\\n**Dynamic Ad Prompt:**\\n${result.ad_prompts.dynamic}\\n\\n**Luxury Ad Prompt:**\\n${result.ad_prompts.luxury}\\n\\n---\\n`;\n}).join('\\n')}\\n\\n## Summary\\nThis report contains SEO-optimized content and advertisement prompts for ${allResults.length} product image${allResults.length > 1 ? 's' : ''}. Use the generated titles and descriptions for your e-commerce listings, and the ad prompts with AI image generators like DALL-E, Midjourney, or Stable Diffusion.\\n`;\n\nconst jsonData = {\n  report_metadata: {\n    timestamp: new Date().toISOString(),\n    total_images: allResults.length,\n    source: firstResult.image_info.source,\n    processing_summary: {\n      images_processed: allResults.length,\n      seo_titles_generated: allResults.length * 3,\n      ad_prompts_generated: allResults.length * 4,\n      total_seo_tags: allResults.reduce((sum, r) => sum + (r.seo_content.seo_tags?.length || 0), 0)\n    }\n  },\n  results: allResults\n};\n\nreturn {\n  json: jsonData,\n  binary: {\n    data: Buffer.from(reportContent).toString('base64'),\n    mimeType: 'text/markdown',\n    fileName: `product_analysis_report_${new Date().toISOString().split('T')[0]}_${allResults.length}images.md`\n  }\n};"
      },
