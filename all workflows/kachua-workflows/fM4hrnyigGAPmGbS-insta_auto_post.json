    {
      "parameters": {
        "jsCode": "// Extract images from different trigger sources\nlet images = [];\nlet source = 'unknown';\nlet responseChannel = null;\n\n// Check if triggered by Discord webhook\nif ($input.item.json.attachments && $input.item.json.attachments.length > 0) {\n  source = 'discord_webhook';\n  responseChannel = $input.item.json.channel_id;\n  \n  // Extract image URLs from Discord attachments\n  $input.item.json.attachments.forEach((attachment, index) => {\n    if (attachment.content_type && attachment.content_type.startsWith('image/')) {\n      images.push({\n        url: attachment.url,\n        filename: attachment.filename || `image_${index + 1}.${attachment.content_type.split('/')[1]}`,\n        index: index\n      });\n    }\n  });\n}\n// Check if triggered by regular webhook with image URLs\nelse if ($input.item.json.image_urls && Array.isArray($input.item.json.image_urls)) {\n  source = 'webhook_array';\n  \n  $input.item.json.image_urls.forEach((url, index) => {\n    images.push({\n      url: url,\n      filename: `product_image_${index + 1}.jpg`,\n      index: index\n    });\n  });\n}\n// Check if single image URL provided\nelse if ($input.item.json.image_url) {\n  source = 'webhook_single';\n  \n  images.push({\n    url: $input.item.json.image_url,\n    filename: 'product_image_1.jpg',\n    index: 0\n  });\n}\n\n// Return array of items for processing\nif (images.length === 0) {\n  return [{\n    json: {\n      error: 'No images found',\n      message: 'Please provide images via Discord attachments or image_url/image_urls parameters'\n    }\n  }];\n}\n\nreturn images.map(image => ({\n  json: {\n    ...image,\n    source: source,\n    responseChannel: responseChannel,\n    totalImages: images.length,\n    originalInput: $input.item.json\n  }\n}));"
      },
