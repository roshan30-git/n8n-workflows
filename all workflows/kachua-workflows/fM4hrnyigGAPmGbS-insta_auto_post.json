    {
      "parameters": {
        "jsCode": "// Parse the JSON responses and structure the output for each image\nconst imageData = $input.item.json;\nconst imageAnalysis = $('Analyze Each Product Image').item.json.choices[0].message.content;\nconst seoContentRaw = $('Generate SEO Content').item.json.choices[0].message.content;\nconst adPromptsRaw = $('Generate Ad Image Prompts').item.json.choices[0].message.content;\n\nlet seoContent, adPrompts;\n\ntry {\n  seoContent = JSON.parse(seoContentRaw);\n} catch (e) {\n  seoContent = { error: 'Failed to parse SEO content', raw: seoContentRaw };\n}\n\ntry {\n  adPrompts = JSON.parse(adPromptsRaw);\n} catch (e) {\n  adPrompts = { error: 'Failed to parse ad prompts', raw: adPromptsRaw };\n}\n\nconst result = {\n  image_info: {\n    index: imageData.index + 1,\n    total_images: imageData.totalImages,\n    filename: imageData.filename,\n    original_url: imageData.url,\n    source: imageData.source\n  },\n  timestamp: new Date().toISOString(),\n  analysis: {\n    product_analysis: imageAnalysis\n  },\n  seo_content: {\n    titles: seoContent.titles || [],\n    meta_description: seoContent.meta_description || '',\n    seo_tags: seoContent.seo_tags || [],\n    product_description: seoContent.product_description || '',\n    call_to_action: seoContent.call_to_action || ''\n  },\n  ad_prompts: {\n    lifestyle: adPrompts.lifestyle_prompt || '',\n    minimalist: adPrompts.minimalist_prompt || '',\n    dynamic: adPrompts.dynamic_prompt || '',\n    luxury: adPrompts.luxury_prompt || ''\n  }\n};\n\nreturn result;"
      },
